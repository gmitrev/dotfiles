[user]
  name = Georgi Mitrev
  email = gvmitrev@gmail.com
  signingkey = 9CAC925B34AD62E5
[github]
  user = gmitrev
[branch]
  autosetuprebase = always
[push]
  default = current
  autoSetupRemote = true
[core]
  pager = delta
  excludesfile = /Users/georgi/.gitignore_global
  editor = nvim -c 'set textwidth=72'
[pull]
  rebase = true
[rerere]
  enabled = true
[pager]
  branch = false
[commit]
  gpgsign = true
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  dark = false
  line-numbers = true
  syntax-theme = gruvbox-light
  hyperlinks = true
[merge]
  conflictStyle = zdiff3
[diff]
  algorithm = histogram
  colorMoved = default
  tool = difftastic
[difftool]
  prompt = false
[difftool "difftastic"]
  cmd = difft "$LOCAL" "$REMOTE"
[alias]
  dft = difftool          ; structural diff: git dft [<rev>]
