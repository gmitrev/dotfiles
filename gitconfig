[github]
  user = gmitrev
[branch]
  autosetuprebase = always
[push]
  default = current
[core]
  pager = diff-highlight | diff-so-fancy | less --tabs=1,5 -R
  excludesfile = /Users/georgi/.gitignore_global
	editor = nvim -c 'set textwidth=72'
[color "diff"]
  meta = yellow bold
  commit = green bold
  frag = magenta bold
  old = red bold
  new = green bold
  whitespace = red reverse
[color "diff-highlight"]
  oldNormal = red bold
  oldHighlight = red bold 52
  newNormal = green bold
  newHighlight = green bold 22
[pull]
  rebase = true
[rerere]
  enabled = true
[pager]
	branch = false
[commit]
	gpgsign = true
[merge]
	conflictstyle = diff3
